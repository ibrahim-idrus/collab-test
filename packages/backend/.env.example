# NeonDB connection string (used for local drizzle-kit commands only)
# In production this is set as a Cloudflare Worker secret via: wrangler secret put DATABASE_URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# PostHog (optional – for server-side analytics)
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
